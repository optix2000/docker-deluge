+
+    def _register_distributions_from_path(self, path):
+        try:
+            dists = Distribution.discover(path=[path])
+        except Exception as ex:
+            log.warning('Failed to discover plugin metadata in %s: %s', path, ex)
+            return
+
+        for dist in dists:
+            self._register_distribution(dist, path)
+
+    @staticmethod
+    def _get_egg_link_path(path):
+        try:
+            with open(path, encoding='utf8') as egg_link:
+                for line in egg_link:
+                    line = line.strip()
+                    if not line:
+                        continue
+                    if os.path.isabs(line):
+                        return line
+                    return os.path.abspath(os.path.join(os.path.dirname(path), line))
+        except OSError as ex:
+            log.warning('Unable to read egg-link %s: %s', path, ex)
+        return None
