+    def _distribution_name(self, dist, metadata, fallback=''):
+        metadata_path = self._path_text(getattr(dist, '_path', '')).rstrip('/\\')
+        metadata_basename = os.path.basename(metadata_path)
+        metadata_basename_lower = metadata_basename.lower()
+
+        if metadata_basename_lower.endswith(('.egg-info', '.dist-info')):
+            basename = metadata_basename
+        elif metadata_basename_lower == 'egg-info':
+            basename = os.path.basename(os.path.dirname(metadata_path))
+        else:
+            basename = os.path.basename(
+                self._distribution_location(dist, fallback).rstrip('/\\')
+            )
+
+        basename_root, ext = os.path.splitext(basename)
+        if ext.lower() in ('.egg', '.egg-info', '.dist-info'):
+            match = LEGACY_DIST_NAME(basename_root)
+            if match and match.group('name'):
+                return self._safe_name(match.group('name'))
+
+        metadata_name = metadata.get('Name')
+        if metadata_name:
+            return self._safe_name(metadata_name)
+        return None
+
+    def _register_distribution(self, dist, location):
+        try:
+            metadata = dist.metadata
+            name = self._distribution_name(dist, metadata, location)
+        except Exception as ex:
+            log.warning('Skipping invalid plugin metadata in %s: %s', location, ex)
+            return
+
+        version = (metadata.get('Version') or '').strip()
+
+        if not name or not version:
+            return
+
+        key = name.lower()
+        if key in self._plugin_dists:
+            return
+
+        self._plugin_dists[key] = dist
+        self.available_plugins.append(name)
+        log.debug(
+            'Found plugin: %s %s at %s',
+            name,
+            version,
+            self._distribution_location(dist, location),
+        )
+
+    def _register_distributions_from_path(self, path):
+        try:
+            dists = Distribution.discover(path=[path])
+        except Exception as ex:
+            log.warning('Failed to discover plugin metadata in %s: %s', path, ex)
+            return
+
+        for dist in dists:
+            self._register_distribution(dist, path)
+
+    @staticmethod
+    def _get_egg_link_path(path):
+        try:
+            with open(path, encoding='utf8') as egg_link:
+                for line in egg_link:
+                    line = line.strip()
+                    if not line:
+                        continue
+                    if os.path.isabs(line):
+                        return line
+                    return os.path.abspath(os.path.join(os.path.dirname(path), line))
+        except OSError as ex:
+            log.warning('Unable to read egg-link %s: %s', path, ex)
+        return None
